{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Backend",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/backend/MesScanner.Backend/MesScanner.Backend.csproj",
      "cwd": "${workspaceFolder}/backend/MesScanner.Backend",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "Frontend (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src",
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack Debug",
      "configurations": [".NET Backend", "Frontend (Chrome)"]
    }
  ]
}
